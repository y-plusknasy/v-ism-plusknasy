# =================================================================
# Docker Development Environment Settings (.env)
# =================================================================

# Database Configuration
# These values are used by compose.yml to set up the MariaDB container
# and by wp-config-docker.php to connect to it.
DB_ROOT_PASSWORD=db_root_password_change_me
DB_NAME=wife_podcast_db
DB_USER=wife_podcast_user
DB_PASSWORD=wife_podcast_password

# Application Logging
# The directory inside the WordPress container where logs will be stored.
# Referenced by themes/generatepress-child/inc/logger.php via getenv('WP_LOG_DIR').
WP_LOG_DIR=/workspace/logs
